# 複製此檔案為 .env 並填入實際值
# cp .env.example .env

# Supabase 連線字串
# 在 Supabase Dashboard > Project Settings > Database > Connection string (URI) 取得
# 使用 Transaction pooler（port 6543）而非 Direct connection（port 5432），
# 因為 collector 是短命連線，pooler 效能更好。
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
